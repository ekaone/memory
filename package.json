{
  "name": "@ekaone/memory",
  "version": "0.1.0",
  "description": "A pluggable memory layer for agent runtimes",
  "keywords": [
    "memory",
    "agent",
    "runtime",
    "sqlite",
    "semantic"
  ],
  "author": {
    "name": "Eka Prasetia",
    "email": "ekaone3033@gmail.com",
    "url": "https://prasetia.me"
  },
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sqlite": {
      "types": "./dist/adapters/sqlite-adapter.d.ts",
      "import": "./dist/adapters/sqlite-adapter.js",
      "require": "./dist/adapters/sqlite-adapter.cjs"
    },
    "./memory": {
      "types": "./dist/adapters/memory-adapter.d.ts",
      "import": "./dist/adapters/memory-adapter.js",
      "require": "./dist/adapters/memory-adapter.cjs"
    },
    "./semantic": {
      "types": "./dist/adapters/semantic-adapter.d.ts",
      "import": "./dist/adapters/semantic-adapter.js",
      "require": "./dist/adapters/semantic-adapter.cjs"
    },
    "./embed": {
      "types": "./dist/embed/types.d.ts",
      "import": "./dist/embed/types.js",
      "require": "./dist/embed/types.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm typecheck && pnpm clean && pnpm tsup",
    "watch": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run clean && pnpm run test && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "better-sqlite3": "^12.10.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ekaone/memory.git"
  },
  "bugs": {
    "url": "https://github.com/ekaone/memory/issues"
  },
  "homepage": "https://github.com/ekaone/memory#readme"
}
